<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ABDANCE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'ab-dark': '#0f0f0f',
                        'ab-accent': '#cda052' // Color sugerido, lo puedes cambiar.
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Google Fonts for Modern Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #0f0f0f;
            color: #ffffff;
            /* overscroll-behavior-y: none; para evitar el rebote */
            overscroll-behavior-y: none;
            margin: 0;
            overflow-x: hidden;
        }
        
        /* Smooth scrolling global, aunque GSAP se encargará del hero */
        html {
            scroll-behavior: smooth;
        }
    </style>
</head>
<body class="antialiased">
    <!-- Header flotante translúcido -->
    <header class="fixed top-0 w-full z-50 backdrop-blur-md bg-black/50 border-b border-white/10 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <!-- Logo Texto -->
                <div class="flex-shrink-0 flex items-center">
                    <a href="#inicio" class="text-2xl font-bold tracking-widest text-white">ABDANCE</a>
                </div>
                <!-- Menú Navegación -->
                <nav class="hidden md:flex space-x-10">
                    <a href="#inicio" class="text-gray-300 hover:text-white transition-colors uppercase text-sm tracking-wider">Inicio</a>
                    <a href="#eventos" class="text-gray-300 hover:text-white transition-colors uppercase text-sm tracking-wider">Eventos</a>
                    <a href="#disciplina" class="text-gray-300 hover:text-white transition-colors uppercase text-sm tracking-wider">Disciplina</a>
                    <a href="#contacto" class="text-gray-300 hover:text-white transition-colors uppercase text-sm tracking-wider">Contacto</a>
                </nav>
            </div>
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="border-t border-white/10 text-center py-8 text-gray-500 mt-20">
        <p>&copy; 2026 - ABDANCE</p>
    </footer>

    <!-- GSAP Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
