<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ABDANCE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'ab-dark': '#0f0f0f',
                        'ab-accent': '#cda052' // Color sugerido, lo puedes cambiar.
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Google Fonts for Modern Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #0f0f0f;
            color: #ffffff;
            /* overscroll-behavior-y: none; para evitar el rebote */
            overscroll-behavior-y: none;
            margin: 0;
            overflow-x: hidden;
        }
        
        /* Smooth scrolling global, aunque GSAP se encargará del hero */
        html {
            scroll-behavior: smooth;
        }
    </style>
</head>
<body class="antialiased">
    <!-- Header flotante translúcido -->
    <header class="fixed top-0 w-full z-50 backdrop-blur-md bg-black/50 border-b border-white/10 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <!-- Logo Texto -->
                <div class="flex-shrink-0 flex items-center">
                    <a href="/" class="text-2xl font-bold tracking-widest text-white">ABDANCE</a>
                </div>
                <!-- Menú Navegación -->
                <nav class="hidden md:flex space-x-10">
                    <a href="/" class="text-gray-300 hover:text-white transition-colors uppercase text-sm tracking-wider">Inicio</a>
                    <a href="/Eventos" class="text-gray-300 hover:text-white transition-colors uppercase text-sm tracking-wider">Eventos</a>
                    <a href="/Disciplina" class="text-gray-300 hover:text-white transition-colors uppercase text-sm tracking-wider">Disciplina</a>
                    <a href="/Contacto" class="text-gray-300 hover:text-white transition-colors uppercase text-sm tracking-wider">Contacto</a>
                </nav>
            </div>
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-black border-t border-white/10 pt-16 pb-8 relative z-50 mt-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
                <!-- Brand -->
                <div class="col-span-1 md:col-span-1">
                    <a href="/" class="text-3xl font-bold tracking-widest text-white mb-4 block">ABDANCE</a>
                    <p class="text-gray-400 font-light text-sm leading-relaxed">
                        Siente el ritmo. Elevando el nivel de la danza con pasión, disciplina y arte.
                    </p>
                </div>
                <!-- Enlaces Rápidos -->
                <div>
                    <h4 class="text-white font-bold mb-4 uppercase tracking-wider text-sm">Explorar</h4>
                    <ul class="space-y-2">
                        <li><a href="/" class="text-gray-400 hover:text-ab-accent transition-colors text-sm font-light">Inicio</a></li>
                        <li><a href="/Eventos" class="text-gray-400 hover:text-ab-accent transition-colors text-sm font-light">Eventos</a></li>
                        <li><a href="/Disciplina" class="text-gray-400 hover:text-ab-accent transition-colors text-sm font-light">Disciplina</a></li>
                    </ul>
                </div>
                <!-- Soporte -->
                <div>
                    <h4 class="text-white font-bold mb-4 uppercase tracking-wider text-sm">Soporte</h4>
                    <ul class="space-y-2">
                        <li><a href="/Contacto" class="text-gray-400 hover:text-ab-accent transition-colors text-sm font-light">Contacto</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-ab-accent transition-colors text-sm font-light">Preguntas Frecuentes</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-ab-accent transition-colors text-sm font-light">Términos y Condiciones</a></li>
                    </ul>
                </div>
                <!-- Redes -->
                <div>
                    <h4 class="text-white font-bold mb-4 uppercase tracking-wider text-sm">Síguenos</h4>
                    <div class="flex space-x-4">
                        <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:bg-ab-accent hover:text-black transition-all">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
                        </a>
                        <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:bg-ab-accent hover:text-black transition-all">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                        </a>
                    </div>
                </div>
            </div>
            <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center">
                <p class="text-gray-500 text-sm font-light mb-4 md:mb-0">&copy; 2026 - ABDANCE. Todos los derechos reservados.</p>
                <p class="text-gray-600 text-sm font-light">Diseñado con <span class="text-ab-accent">&hearts;</span> para la danza.</p>
            </div>
        </div>
    </footer>

    <!-- GSAP Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
