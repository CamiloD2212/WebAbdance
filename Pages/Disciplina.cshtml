@page
@model WebAbdance.Pages.DisciplinaModel
@{
    ViewData["Title"] = "Disciplina";
}

<div class="min-h-screen bg-black py-32 px-4">
    <div class="max-w-7xl mx-auto">
        <h2 class="text-4xl md:text-6xl font-bold mb-12 text-center text-white">Disciplina</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="h-64 bg-gray-800 rounded-lg flex items-center justify-center hover:bg-ab-accent transition-colors cursor-pointer group">
                <span class="text-xl font-bold group-hover:text-black transition-colors">Hip Hop</span>
            </div>
            <div class="h-64 bg-gray-800 rounded-lg flex items-center justify-center hover:bg-ab-accent transition-colors cursor-pointer group">
                <span class="text-xl font-bold group-hover:text-black transition-colors">Jazz</span>
            </div>
            <div class="h-64 bg-gray-800 rounded-lg flex items-center justify-center hover:bg-ab-accent transition-colors cursor-pointer group">
                <span class="text-xl font-bold group-hover:text-black transition-colors">Contemporáneo</span>
            </div>
            <div class="h-64 bg-gray-800 rounded-lg flex items-center justify-center hover:bg-ab-accent transition-colors cursor-pointer group">
                <span class="text-xl font-bold group-hover:text-black transition-colors">Ballet</span>
            </div>
        </div>
    </div>
</div>
