@page
@model WebAbdance.Pages.ContactoModel
@{
    ViewData["Title"] = "Contacto";
}

<div class="min-h-screen bg-ab-dark py-32 px-4 flex items-center">
    <div class="max-w-3xl mx-auto w-full bg-gray-900 p-8 rounded-2xl shadow-2xl border border-white/5">
        <h2 class="text-4xl font-bold mb-8 text-center text-white">Contacto</h2>
        <form class="space-y-6">
            <div>
                <label class="block text-sm font-medium text-gray-400 mb-2">Nombre</label>
                <input type="text" class="w-full bg-black/50 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-ab-accent transition-colors" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-400 mb-2">Email</label>
                <input type="email" class="w-full bg-black/50 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-ab-accent transition-colors" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-400 mb-2">Mensaje</label>
                <textarea rows="4" class="w-full bg-black/50 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-ab-accent transition-colors"></textarea>
            </div>
            <button type="button" class="w-full bg-ab-accent text-black font-bold py-4 rounded-lg hover:bg-yellow-500 transition-colors">Enviar Mensaje</button>
        </form>
    </div>
</div>
